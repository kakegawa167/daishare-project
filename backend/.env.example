# DB接続
# ローカル: Supabase CLI の PostgreSQL (supabase start で起動)
# staging/prod: Supabase managed PostgreSQL の接続文字列
DATABASE_URL=postgresql+asyncpg://postgres:postgres@host.docker.internal:54322/postgres

# Supabase JWT検証
# Supabase Dashboard > Project Settings > API > JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Supabase Storage操作用（Service Role Key）
# Supabase Dashboard > Project Settings > API > service_role key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# CORS
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006

# 環境
ENVIRONMENT=local
